#include <winresrc.h>
#include "resource.h"

// Icon (use a default system icon as placeholder if .ico not present)
IDI_XCLIP ICON "xclip.ico"

// Version info
VS_VERSION_INFO VERSIONINFO
FILEVERSION    1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "FileDescription", "XClip Clipboard Manager"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "XClip"
            VALUE "LegalCopyright", "2026"
            VALUE "OriginalFilename", "XClip.exe"
            VALUE "ProductName", "XClip"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

// Manifest for visual styles
// (handled via linker flag instead)
